# Copy to keystore.properties (gitignored) and fill in real values.
# Generate the keystore once:
#   keytool -genkey -v \
#     -keystore ~/pocket-technician-release.jks \
#     -alias pockettechnician \
#     -keyalg RSA -keysize 2048 -validity 10000

storeFile=/absolute/path/to/pocket-technician-release.jks
storePassword=your-store-password
keyAlias=pockettechnician
keyPassword=your-key-password